#!/usr/bin/env bash
# Capture the caller's directory before bun --cwd replaces PWD.
export OPENTERMINAL_CWD="$PWD"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OPENTERMINAL_ROOT="$(dirname "$SCRIPT_DIR")"
exec bun run --cwd "$OPENTERMINAL_ROOT" --conditions=browser ./src/index.ts "$@"
